# Credenciales de Microsoft Graph (Buzón O365) — copia este archivo a .env y
# rellena los valores. NO subir .env al repositorio.
GRAPH_CLIENT_ID=tu-client-id
GRAPH_TENANT_ID=tu-tenant-id

# Cuenta de servicio de BigQuery (dashboard de cobranza mensual). Ruta al JSON
# de credenciales, relativa a la raíz del proyecto. NO subir ese JSON al repo.
BIGQUERY_CREDENTIALS_PATH=app/credentials/bq.json
